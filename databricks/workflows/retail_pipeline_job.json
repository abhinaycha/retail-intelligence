{
  "name": "retail_intelligence_pipeline",
  "description": "E2E Retail Intelligence: DLT Bronze → dbt Silver/Gold → ML Forecast → Dashboard",
  "tags": {"project": "retail_intelligence", "env": "prod"},
  "job_clusters": [
    {
      "job_cluster_key": "main_cluster",
      "new_cluster": {
        "spark_version": "14.3.x-scala2.12",
        "node_type_id": "i3.xlarge",
        "num_workers": 2,
        "spark_conf": {
          "spark.databricks.delta.preview.enabled": "true"
        }
      }
    }
  ],
  "tasks": [
    {
      "task_key": "01_dlt_bronze_silver",
      "description": "Run DLT pipeline: Bronze ingestion → Silver cleaning",
      "pipeline_task": {
        "pipeline_id": "REPLACE_WITH_DLT_PIPELINE_ID",
        "full_refresh": false
      }
    },
    {
      "task_key": "02_dbt_silver_gold",
      "description": "Run dbt: Silver incremental models + Gold aggregations",
      "depends_on": [{"task_key": "01_dlt_bronze_silver"}],
      "job_cluster_key": "main_cluster",
      "notebook_task": {
        "notebook_path": "/Repos/er.abhinay2011@gmail.com/retail-intelligence/databricks/notebooks/run_dbt",
        "base_parameters": {
          "dbt_command": "dbt run --select silver gold"
        }
      }
    },
    {
      "task_key": "03_dbt_snapshots",
      "description": "Run dbt snapshots (SCD Type 2)",
      "depends_on": [{"task_key": "02_dbt_silver_gold"}],
      "job_cluster_key": "main_cluster",
      "notebook_task": {
        "notebook_path": "/Repos/er.abhinay2011@gmail.com/retail-intelligence/databricks/notebooks/run_dbt",
        "base_parameters": {"dbt_command": "dbt snapshot"}
      }
    },
    {
      "task_key": "04_ml_forecast",
      "description": "Run demand forecasting model + write predictions to Gold",
      "depends_on": [{"task_key": "03_dbt_snapshots"}],
      "job_cluster_key": "main_cluster",
      "notebook_task": {
        "notebook_path": "/Repos/er.abhinay2011@gmail.com/retail-intelligence/databricks/notebooks/05_ml_forecasting"
      }
    },
    {
      "task_key": "05_optimize",
      "description": "OPTIMIZE + Z-ORDER all Silver and Gold tables",
      "depends_on": [{"task_key": "04_ml_forecast"}],
      "job_cluster_key": "main_cluster",
      "notebook_task": {
        "notebook_path": "/Repos/er.abhinay2011@gmail.com/retail-intelligence/databricks/notebooks/04_optimize_vacuum"
      }
    }
  ],
  "schedule": {
    "quartz_cron_expression": "0 0 6 * * ?",
    "timezone_id": "America/New_York",
    "pause_status": "UNPAUSED"
  },
  "email_notifications": {
    "on_failure": ["er.abhinay2011@gmail.com"]
  }
}
